{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Encrypt and Sign Plugin (v2)",
            "type": "shell",
            "command": "echo Encrypting and signing Plugin",
            "windows": {
                "command": ".\\pluginsigning\\plugin_tool.exe encrypt -i \"${workspaceFolderBasename}.qplug\" -m CoreAndEmulate && .\\pluginsigning\\plugin_tool.exe sign -v 2 -k .\\pluginsigning\\plugin_signing_private_v2.pem -p \"preset leases doormat strata\" -i \"${workspaceFolder}\\${workspaceFolderBasename}.qplugx2\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [],
        },
        {
            "label": "Compile QSD Plugin",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "command": "echo Update QSD Plugin",
            "windows": {
                "command": ".\\plugincompile\\copy_plugin.cmd \"${workspaceFolder}\" \"${workspaceFolderBasename}\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [],
            "dependsOn": [ "--" ]
        },
        {
            "label": "--",
            "type": "shell",
            "group": "build",
            "command": "echo Compile Plugin",
            "windows": {
                "command": ".\\plugincompile\\PLUGCC.exe \"${workspaceFolderBasename}\" \"${workspaceFolder}\\plugin.lua\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [],
            "dependsOn": [ "-" ]
        },
        {
            "label": "-",
            "type": "shell",
            "group": "build",
            "command": "echo Version",
            "windows": {
                "command": "sh .\\plugincompile\\compile_plugin.sh ${input:ver_inc}",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "Sign QSD Plugin (v1)",
            "type": "shell",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "command": "echo Update Signed QSD Plugin (v1)",
            "windows": {
                "command": ".\\plugincompile\\copy_plugin.cmd \"${workspaceFolder}\" \"${workspaceFolderBasename}\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [],
            "dependsOn": [ "---" ]
        },
        {
            "label": "---",
            "type": "shell",
            "command": "echo Sign Plugin (v1)",
            "windows": {
                "command": ".\\pluginsigning\\plugin_tool.exe sign -v 1 -i \"${workspaceFolder}\\${workspaceFolderBasename}.qplug\" -o \"${workspaceFolder}\\${workspaceFolderBasename}.qplug\" -k .\\pluginsigning\\plugin_signing_key.pem -p \"next scrutiny doses receives\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c"  ]
                    }
                }
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "ver_inc",
            "description": "Version Inc:",
            "type": "pickString",
            "options": [
                "ver_maj",
                "ver_min",
                "ver_fix",
                "ver_dev",
                "ver_none",
                "CANCEL"
            ],
            "default": "ver_dev"
        }
    ]
}